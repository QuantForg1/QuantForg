# =============================================================================
# QuantForg Environment Configuration
# Copy this file to .env and adjust values for your environment.
# Never commit .env — it contains secrets.
# =============================================================================

# Application
APP_NAME=QuantForg
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
# Prefer CORS_ALLOWED_ORIGINS in production (alias of CORS_ORIGINS).
# Must include every browser origin that calls the API. Production also allows
# https://*.vercel.app and https://*.quantforg.com via CORS regex.
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
# CORS_ALLOWED_ORIGINS=https://www.quantforg.com,https://quantforg.com

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
# Dev-only. Production/Railway entrypoint ALWAYS forces RELOAD=false (do not set true in Railway).
RELOAD=true
# HEALTH_HTTP_STRICT=false  # default: /health returns HTTP 200 even if deps degraded

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
LOG_JSON=false

# PostgreSQL (preferred for app Settings.database_url)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=quantforg
POSTGRES_PASSWORD=quantforg_dev_password_change_me
POSTGRES_DB=quantforg
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_ECHO=false
# Optional explicit URL (Railway / PaaS / Supabase pooler). Overrides POSTGRES_*.
# Prefer session pooler for Railway: postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# DATABASE_URL=postgresql://quantforg:change-me@localhost:5432/quantforg
# POSTGRES_SSL=true   # optional force; auto-detected for supabase/railway/neon hosts

# Supabase (never commit real keys — copy to .env only)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# When DATABASE_URL is unset, SUPABASE_DB_PASSWORD + SUPABASE_URL compose the
# session-pooler DSN (aws-0-<region>.pooler.supabase.com:5432).
SUPABASE_DB_PASSWORD=
AUTH_REDIRECT_URL=http://localhost:3000/auth/callback
# Production: AUTH_REDIRECT_URL=https://www.quantforg.com/auth/callback
AUTH_OAUTH_ENABLED=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_POOL_SIZE=10
# Optional full Redis URL (Railway). When set, overrides REDIS_* composition.
# If REDIS_URL is unset, Redis is treated as intentionally disabled (health=disabled).
# REDIS_URL=redis://localhost:6379/0

# Security
# JWT signing + general app secret (maps to Settings.secret_key).
# Operators may also provide JWT_SECRET as an alias in deployment platforms;
# wire it to SECRET_KEY in the orchestrator if using that name.
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-64-chars
# JWT_SECRET=   # alias — set equal to SECRET_KEY in staging/prod secret stores
# ENCRYPTION_KEY=  # alias — credential encryption uses SECRET_KEY + ENCRYPTION_KEY_VERSION
ENCRYPTION_KEY_VERSION=1
# Comma-separated prior secrets for credential key rotation (optional)
# CREDENTIAL_ENCRYPTION_PREVIOUS_KEYS=
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Observability
HEALTH_CHECK_TIMEOUT_SECONDS=5.0

# Persistence — durable Postgres UoWs outside testing (set false to force memory)
DURABLE_PERSISTENCE=true

# MT5 Adapter (connection layer — mock by default; no live trading)
MT5_ENABLED=true
MT5_USE_MOCK=true
MT5_TERMINAL_PATH=
MT5_CONNECT_TIMEOUT_SECONDS=60.0

# Execution Gateway — set EXECUTION_ENABLED=true only with a live MT5 gateway
# (MT5_GATEWAY_BASE_URL + token). Never invents fills without the gateway trade API.
EXECUTION_ENABLED=false

# Closed beta — invite secret is SERVER-ONLY (never NEXT_PUBLIC_*)
# BETA_MODE=true
# BETA_INVITE_CODE=rotate-this-secret

# ---------------------------------------------------------------------------
# MT5 Windows Gateway bridge (Railway / API process)
# MT5_GATEWAY_CALLER_TOKEN must match Windows MT5_GATEWAY_TOKEN EXACTLY
# (character-for-character). A single mistyped letter (e.g. Lm vs Ln) causes
# identical masks/lengths but HTTP 401. Do not commit the real secret.
# Canonical host source: repo-root .env → MT5_GATEWAY_TOKEN
# Canonical caller source: Railway variable MT5_GATEWAY_CALLER_TOKEN (same value)
# ---------------------------------------------------------------------------
# MT5_GATEWAY_BASE_URL=https://xxxx.trycloudflare.com
# MT5_GATEWAY_CALLER_TOKEN=replace-with-same-token-as-windows-gateway

# ---------------------------------------------------------------------------
# MT5 Windows Gateway (separate process — NOT Railway)
# Broker credentials must NEVER be stored in Railway.
# Full template: deploy/mt5_gateway/gateway.env.example
# ---------------------------------------------------------------------------
# MT5_GATEWAY_TOKEN=replace-with-strong-random-token
# MT5_GATEWAY_HOST=127.0.0.1
# MT5_GATEWAY_PORT=8765
# MT5_GATEWAY_ENABLE_WEBSOCKET=true
# MT5_GATEWAY_AUTO_ATTACH=true
# MT5_HEARTBEAT_INTERVAL_SECONDS=5
# MT5_RECONNECT_ENABLED=true
# MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Market Intelligence — optional licensed JSON feeds (leave empty to return no invented news)
NEWS_INTELLIGENCE_FEED_URL=
ECONOMIC_CALENDAR_FEED_URL=

# Official provider API keys (empty = provider unconfigured; never fabricates data)
FINNHUB_API_KEY=
TRADING_ECONOMICS_API_KEY=
TWELVEDATA_API_KEY=
ALPHAVANTAGE_API_KEY=
POLYGON_API_KEY=
BINANCE_MARKET_DATA_ENABLED=true
