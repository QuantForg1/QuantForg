# =============================================================================
# QuantForg Environment Configuration
# Copy this file to .env and adjust values for your environment.
# Never commit .env — it contains secrets.
# =============================================================================

# Application
APP_NAME=QuantForg
APP_VERSION=0.1.0
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
ALLOWED_HOSTS=localhost,127.0.0.1,testserver
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=console
LOG_JSON=false

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=quantforg
POSTGRES_PASSWORD=quantforg_dev_password_change_me
POSTGRES_DB=quantforg
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_ECHO=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_POOL_SIZE=10

# Security
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-64-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
ALGORITHM=HS256

# Observability
HEALTH_CHECK_TIMEOUT_SECONDS=5.0
