NEXT_PUBLIC_API_BASE_URL=https://quantforg-production.up.railway.app/api/v1
# Canonical browser origin for metadata / SSR. On Vercel, leave unset to use
# VERCEL_URL, or set to https://www.quantforg.com for production.
NEXT_PUBLIC_APP_URL=https://www.quantforg.com
# Keep false for production validation (no fabricated AI answers).
NEXT_PUBLIC_MOCK_AI=false
# Railway CORS must allow this origin. Production API also allows
# https://*.vercel.app and https://*.quantforg.com via CORS regex.
# Recommended Railway CORS_ALLOWED_ORIGINS:
#   https://www.quantforg.com,https://quantforg.com

# --- Observability / beta (frontend) ---
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_BUILD_VERSION=
# Optional shipping of client errors / audit / feedback (never include secrets).
NEXT_PUBLIC_ERROR_WEBHOOK_URL=
NEXT_PUBLIC_AUDIT_WEBHOOK_URL=
NEXT_PUBLIC_FEEDBACK_WEBHOOK_URL=

# Feature flags (default on unless set to "false"; beta defaults off unless "true")
NEXT_PUBLIC_FF_AI=true
NEXT_PUBLIC_FF_MT5=true
NEXT_PUBLIC_FF_PAPER=true
NEXT_PUBLIC_FF_WORKSPACE=true
NEXT_PUBLIC_FF_BETA=false

# Closed beta / ops modes
# Closed Beta:
#   NEXT_PUBLIC_BETA_MODE=true          # public UI gate flag only
#   BETA_INVITE_CODE=<secret>           # set on API/Railway — never NEXT_PUBLIC
#   NEXT_PUBLIC_MAINTENANCE_MODE=false
#   NEXT_PUBLIC_READ_ONLY_MODE=false
NEXT_PUBLIC_BETA_MODE=false
NEXT_PUBLIC_MAINTENANCE_MODE=false
NEXT_PUBLIC_READ_ONLY_MODE=false
