# QuantForg MT5 Gateway — Windows host environment ONLY
# Copy to repo root as `.env` lines, or load via process / NSSM AppEnvironmentExtra.
# NEVER put broker login/password/server here for Railway.
# NEVER commit real tokens.

# Required — shared bearer for gateway REST/WS (generate a strong random value)
# Must match Railway MT5_GATEWAY_CALLER_TOKEN exactly (no quotes, no trailing spaces).
# Character-for-character: a single typo (e.g. Lm vs Ln) yields matching masks but 401.
# If NSSM/Windows User env also sets MT5_GATEWAY_TOKEN, remove the stale value —
# a mismatch causes HTTP 401 on /session/status while /health still returns 200.
MT5_GATEWAY_TOKEN=replace-with-strong-random-token

# Auth diagnostics (masked first/last 6 chars only) — set false when stable
MT5_GATEWAY_AUTH_DEBUG=false

# Bind
MT5_GATEWAY_HOST=127.0.0.1
MT5_GATEWAY_PORT=8765

# Optional path to terminal64.exe when multiple MT5 installs exist
# MT5_TERMINAL_PATH=C:\Program Files\MetaTrader 5\terminal64.exe

# Local DX: adopt already logged-in terminal on startup (no broker password collected)
# Leave false on exposed hosts unless the terminal is operator-managed on a private network.
MT5_GATEWAY_AUTO_ATTACH=true

MT5_GATEWAY_ENABLE_WEBSOCKET=true
MT5_HEARTBEAT_INTERVAL_SECONDS=5
MT5_RECONNECT_ENABLED=true
MT5_RECONNECT_MAX_ATTEMPTS=5
MT5_RECONNECT_BACKOFF_SECONDS=2
